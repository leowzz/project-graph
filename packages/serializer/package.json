{
  "name": "@graphif/serializer",
  "description": "Serialize instances to objects",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "type-check": "tsc",
    "publish": "pnpm publish --no-git-checks"
  },
  "devDependencies": {
    "@types/js-md5": "^0.8.0",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "js-md5": "^0.8.3",
    "reflect-metadata": "^0.2.2"
  }
}
